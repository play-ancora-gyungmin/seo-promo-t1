---
import Container from '../../components/layout/Container.astro';
import LandingLayout from '../../components/layout/LandingLayout.astro';
import SectionShell from '../../components/layout/SectionShell.astro';
import { getLandingEntry } from '../../lib/landing/getLandingEntry';
import { getLandingSkeletonSections } from '../../lib/landing/getLandingSkeletonSections';

const entry = await getLandingEntry('sample-math-teacher');
const sections = getLandingSkeletonSections(
  entry.data.enabledSections,
  entry.data.sectionOrder
);
---

<LandingLayout landing={entry.data}>
  <Container class="page-spacer page-sections">
    {sections.map((section) => (
      <SectionShell
        id={section.id}
        eyebrow={section.label}
        class="section-shell--placeholder"
      />
    ))}
  </Container>
</LandingLayout>
