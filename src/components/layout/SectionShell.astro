---
import type { LandingSectionKind } from '../../types/landing';

export interface Props {
  id?: string;
  kind?: LandingSectionKind;
  class?: string;
  surfaceClass?: string;
  noSurface?: boolean;
}

const {
  id,
  kind = 'flow',
  class: className = '',
  surfaceClass = '',
  noSurface = false
} = Astro.props;
---

<section
  id={id}
  class:list={['landing-section', `landing-section--${kind}`, className]}
  data-slide-section={kind === 'slide' ? '' : undefined}
  data-section-kind={kind}
  data-is-active={kind === 'slide' ? 'false' : undefined}
>
  <div
    class:list={[
      'landing-section__surface',
      !noSurface && 'section-shell',
      noSurface && 'landing-section__surface--bare',
      surfaceClass
    ]}
  >
    <slot />
  </div>
</section>
