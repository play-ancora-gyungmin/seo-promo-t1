---
import type { ContactChannel, LandingData, LandingSectionConfig } from '../../types/landing';
import bandIcon from '../../assets/icons/contact/band.svg';
import instagramIcon from '../../assets/icons/contact/instagram.png';
import kakaoIcon from '../../assets/icons/contact/kakao.svg';
import naverBlogIcon from '../../assets/icons/contact/naver-blog.svg';
import Container from '../layout/Container.astro';
import SectionShell from '../layout/SectionShell.astro';
import NaverMap from '../ui/NaverMap.astro';

export interface Props {
  section: LandingSectionConfig;
  landing: LandingData;
}

const { section, landing } = Astro.props;
const contact = landing.contact;
const title = contact?.title?.trim() || '문의';
const mapId = `${section.id}-naver-map`;
const academyLogo = landing.brand?.academyLogo;
const locations =
  contact?.locations?.flatMap((location) => {
    const name = location.name?.trim();
    const address = location.address?.trim();
    const phone = location.phone?.trim();
    const latitude = location.latitude;
    const longitude = location.longitude;

    return name || address || phone
      ? [
          {
            name,
            address,
            phone,
            latitude,
            longitude,
            telHref: phone ? `tel:${phone.replace(/[^\d+]/g, '')}` : undefined
          }
        ]
      : [];
  }) ?? [];

const mapLabel =
  locations[0]?.name?.trim() ||
  landing.brand?.brandName?.trim() ||
  '학원';

const mapMarkers = locations.flatMap((location) => {
  const name = location.name?.trim();
  const address = location.address?.trim();
  const phone = location.phone?.trim();
  const latitude = location.latitude;
  const longitude = location.longitude;

  return name || address
    ? [
        {
          name,
          address,
          phone,
          latitude,
          longitude
        }
      ]
    : [];
});

const channels =
  contact?.channels?.flatMap((channel) => {
    const kind = channel.kind;
    const label = channel.label?.trim();
    const href = channel.href?.trim();

    return kind && label && href
      ? [
          {
            kind,
            label,
            href
          }
        ]
      : [];
  }) ?? [];

type IconChannelKind = Exclude<NonNullable<ContactChannel['kind']>, 'website'>;

const iconUrls: Record<IconChannelKind, string> = {
  kakao: kakaoIcon.src,
  instagram: instagramIcon.src,
  blog: naverBlogIcon.src,
  band: bandIcon.src
};

const iconChannels = channels.filter(
  (channel): channel is { kind: IconChannelKind; label: string; href: string } =>
    channel.kind !== 'website'
);
const websiteChannels = channels.filter((channel) => channel.kind === 'website');
const actionCount = Math.max(iconChannels.length, 1);
const actionGroupStyle = `--contact-action-count:${actionCount};`;
---

<SectionShell
  id={section.id}
  kind={section.kind}
  class="contact-section"
  surfaceClass="contact-section__surface"
>
  <Container class="contact-section__container">
    <div class="contact-section__grid">
      <div class="contact-section__content">
        <h2 class="contact-section__title">{title}</h2>

        <div class="contact-section__info">
          {locations.map((location) => (
            <div class="contact-section__location">
              {location.name ? <p class="contact-section__location-name">{location.name}</p> : null}
              {location.phone && location.telHref ? (
                <a class="contact-section__phone" href={location.telHref}>
                  {location.phone}
                </a>
              ) : null}
              {location.address ? <p class="contact-section__address">{location.address}</p> : null}
            </div>
          ))}
        </div>

        {
          iconChannels.length ? (
            <div class="contact-section__links" aria-label="문의 채널" style={actionGroupStyle}>
              {iconChannels.map((channel) => (
                <a
                  class="contact-section__icon-link"
                  href={channel.href}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={channel.label}
                >
                  <img src={iconUrls[channel.kind]} alt="" loading="lazy" />
                </a>
              ))}
            </div>
          ) : null
        }

        {
          websiteChannels.length ? (
            <div class="contact-section__website-links" style={actionGroupStyle}>
              {websiteChannels.map((channel) => (
                <a
                  class="contact-section__text-link"
                  href={channel.href}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={channel.label}
                >
                  {academyLogo ? (
                    <img
                      class="contact-section__text-link-logo"
                      src={academyLogo.src}
                      alt=""
                      width={academyLogo.width}
                      height={academyLogo.height}
                      decoding="async"
                      aria-hidden="true"
                    />
                  ) : (
                    channel.label
                  )}
                </a>
              ))}
            </div>
          ) : null
        }
      </div>

      <div
        class="contact-section__map"
        role="region"
        aria-label={`${mapLabel} 위치 지도`}
      >
        <NaverMap
          mapId={mapId}
          markers={mapMarkers}
          mapLabel={mapLabel}
        />
      </div>
    </div>
  </Container>
</SectionShell>
