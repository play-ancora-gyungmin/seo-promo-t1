---
import type { LandingData } from '../../types/landing';
import { getLandingSkeletonSections } from '../../lib/landing/getLandingSkeletonSections';
import SectionShell from '../layout/SectionShell.astro';
import CurriculumSection from './CurriculumSection.astro';
import HeroSection from './HeroSection.astro';
import ProofSection from './ProofSection.astro';
import ScoreProofSection from './ScoreProofSection.astro';
import TeacherIntroSection from './TeacherIntroSection.astro';

export interface Props {
  landing: LandingData;
}

const { landing } = Astro.props;
const sections = getLandingSkeletonSections(
  landing.sections,
  landing.enabledSections,
  landing.sectionOrder
);
let curriculumIndex = 0;
const heroSections = sections.filter((section) => section.type === 'hero');
const nonHeroSections = sections.filter((section) => section.type !== 'hero');
---

{
  heroSections.map((section) => (
    <HeroSection section={section} landing={landing} />
  ))
}

{
  nonHeroSections.length ? (
    <div class="landing-deck__continuum">
      {nonHeroSections.map((section) => (
        section.type === 'scoreProof' ? (
          <ScoreProofSection section={section} landing={landing} />
        ) : section.type === 'proof' ? (
          <ProofSection section={section} landing={landing} />
        ) : section.type === 'teacherIntro' ? (
          <TeacherIntroSection section={section} landing={landing} />
        ) : section.type === 'curriculum' ? (
          <CurriculumSection
            section={section}
            landing={landing}
            curriculumIndex={curriculumIndex++}
          />
        ) : (
          <SectionShell id={section.id} kind={section.kind}>
            <span class="landing-placeholder-label">{section.label}</span>
          </SectionShell>
        )
      ))}
    </div>
  ) : null
}
